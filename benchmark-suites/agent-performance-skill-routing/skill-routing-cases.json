      "covers": [
        "benchmark-agent-configs"
      ],
      "prompt": "Design a matched benchmark for a baseline agent configuration and one treatment. Freeze conditions, blinding, safety vetoes, and the claim gate, but do not run candidates or declare a winner.",
      "expected": {
        "selected_skills": [
          "benchmark-agent-configs"
        ],
        "boundary": "analysis_only",
        "required_behaviors": [
          "freeze_matched_conditions",
          "separate_output_process_and_harness",
          "use_exact_request_boundary"
        ],
        "forbidden_behaviors": [
          "claim_without_fresh_evidence",
          "create_external_state",
          "edit_repository",
          "run_unfrozen_comparison",
          "use_static_inspection_for_winner"
