{
  "schema": "conductor.workflow.v1",
  "name": "profiled-review",
  "description": "Run reusable policy-bounded reviewer profiles over independent repository scopes.",
  "mode": "read_only",
  "risk": "medium",
  "max_workers": 4,
  "agent_map_max_total_tokens": 64000,
  "agent_profiles": [
    {
      "schema": "conductor.agent_profile.v1",
      "name": "correctness-reviewer",
      "description": "A reusable read-only implementation reviewer.",
      "instructions": "Inspect only the assigned scope. Check behavior, boundary cases, callers, and tests. Do not edit files. Return prioritized findings with concrete file evidence, verification performed, and remaining uncertainty.",
      "model": "gpt-5.6-sol",
      "effort": "high",
      "max_tokens": 4000,
      "sandbox": "read-only",
      "tool_policy": "isolated",
      "tool_output_token_limit": 2000,
      "risk": "medium",
      "max_workers": 4,
      "timeout_seconds": 900,
      "memory": {
        "mode": "read-only",
        "max_entries": 16,
        "max_bytes": 32768
      }
    }
  ],
  "steps": [
    {
      "id": "profiled-fanout",
      "kind": "agent_map",
      "description": "Apply the same immutable reviewer contract to independent scopes.",
      "risk": "medium",
      "agent_profile": "correctness-reviewer",
      "items": [
        "public API and caller compatibility",
        "error handling and boundary behavior",
        "test coverage and hidden assumptions",
        "concurrency, retries, and idempotency"
      ],
      "prompt_template": "Review this focus area: {item}",
      "max_total_tokens": 16000,
      "max_packets": 4,
      "capture_dir": "agent/profiled-review",
      "max_workers": 4
    }
  ]
}
