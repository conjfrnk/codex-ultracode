{
  "schema": "conductor.workflow.v1",
  "name": "verification-sweep",
  "description": "Run conservative local validation commands and collect evidence.",
  "mode": "read_only",
  "risk": "low",
  "max_workers": 1,
  "default_timeout_seconds": 240,
  "steps": [
    {
      "id": "runtime-help",
      "kind": "shell",
      "description": "Verify the runtime CLI imports and exposes help.",
      "risk": "low",
      "writes": false,
      "command": ["python3", "-B", "-m", "conductor_runtime", "--help"],
      "capture": "verification/runtime-help.txt"
    },
    {
      "id": "runtime-tests",
      "kind": "shell",
      "description": "Run focused runtime and project tests.",
      "risk": "low",
      "writes": true,
      "command": ["python3", "-B", "-m", "unittest", "discover", "-s", "tests"],
      "capture": "verification/unittest.txt"
    },
    {
      "id": "skill-audit",
      "kind": "shell",
      "description": "Ensure the prompt-only skill still passes its local audit.",
      "risk": "low",
      "writes": false,
      "command": ["python3", "-B", "tools/run_local_audit.py", "codex-conductor"],
      "capture": "verification/skill-audit.txt"
    }
  ]
}
